generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Case {
  id         Int       @id @default(autoincrement())
  caseNumber String    @unique
  category   String
  status     String    @default("pending")
  priority   String    @default("medium")
  judgeId    Int?
  caseName   String
  description String   @default("")
  actionDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  judge Judge? @relation(fields: [judgeId], references: [id])

  @@index([category, status])
}

model Judge {
  id        Int    @id @default(autoincrement())
  name      String
  courtRoom String

  cases Case[]
}

model Lawyer {
  id    Int    @id @default(autoincrement())
  name  String
  barId String @unique
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  barCouncilId String?
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status, role])
}
